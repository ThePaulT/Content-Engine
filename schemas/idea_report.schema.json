{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kudwa-lab/schemas/idea_report.schema.json",
  "title": "idea_report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "account_target", "input_paths", "ideas"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "account_target": { "type": "string", "enum": ["kudwa", "karl", "sam"] },
    "input_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classified", "patterns"],
      "properties": {
        "classified": { "type": "string", "minLength": 1 },
        "patterns": { "type": "string", "minLength": 1 }
      }
    },
    "ideas": {
      "type": "array",
      "minItems": 10,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "working_title",
          "content_lane",
          "format",
          "hook",
          "payload_type",
          "core_angle",
          "why_it_works",
          "visual_needs"
        ],
        "properties": {
          "working_title": { "type": "string", "minLength": 6 },
          "content_lane": { "type": "string", "minLength": 3 },
          "format": { "type": "string", "minLength": 3 },
          "hook": { "type": "string", "minLength": 10 },
          "payload_type": { "type": "string", "minLength": 3 },
          "core_angle": { "type": "string", "minLength": 20 },
          "why_it_works": { "type": "string", "minLength": 20 },
          "visual_needs": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 3 }
          }
        }
      }
    }
  }
}
