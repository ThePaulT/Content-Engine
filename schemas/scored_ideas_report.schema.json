{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kudwa-lab/schemas/scored_ideas_report.schema.json",
  "title": "scored_ideas_report",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_at", "input_paths", "results"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "input_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ideas"],
      "properties": {
        "ideas": { "type": "string", "minLength": 1 },
        "recent_ideas": { "type": "string" },
        "published_history": { "type": "string" }
      }
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "working_title",
          "scores",
          "overall_score",
          "decision",
          "critique",
          "rewrite_hint",
          "too_similar",
          "similarity_reasons"
        ],
        "properties": {
          "working_title": { "type": "string", "minLength": 1 },
          "scores": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "hook_strength",
              "specificity",
              "payload",
              "account_fit",
              "distinctiveness",
              "repetition_risk",
              "save_share_value",
              "commercial_usefulness"
            ],
            "properties": {
              "hook_strength": { "type": "integer", "minimum": 0, "maximum": 10 },
              "specificity": { "type": "integer", "minimum": 0, "maximum": 10 },
              "payload": { "type": "integer", "minimum": 0, "maximum": 10 },
              "account_fit": { "type": "integer", "minimum": 0, "maximum": 10 },
              "distinctiveness": { "type": "integer", "minimum": 0, "maximum": 10 },
              "repetition_risk": { "type": "integer", "minimum": 0, "maximum": 10 },
              "save_share_value": { "type": "integer", "minimum": 0, "maximum": 10 },
              "commercial_usefulness": { "type": "integer", "minimum": 0, "maximum": 10 }
            }
          },
          "overall_score": { "type": "number", "minimum": 0, "maximum": 10 },
          "decision": { "type": "string", "enum": ["keep", "revise", "kill"] },
          "critique": { "type": "string", "minLength": 10 },
          "rewrite_hint": { "type": "string", "minLength": 10 },
          "too_similar": { "type": "boolean" },
          "similarity_reasons": {
            "type": "array",
            "items": { "type": "string", "minLength": 3 }
          }
        }
      }
    }
  }
}
