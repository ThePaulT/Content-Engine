{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kudwa-lab/schemas/url_input.schema.json",
  "title": "url_input",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["url"],
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "source_type_hint": {
            "type": "string",
            "enum": [
              "blog",
              "product_page",
              "resource_hub",
              "case_study",
              "changelog",
              "social_post",
              "unknown"
            ],
            "default": "unknown"
          },
          "notes": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    }
  }
}
