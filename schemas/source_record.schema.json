{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kudwa-lab/schemas/source_record.schema.json",
  "title": "source_record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_id",
    "url",
    "domain",
    "source_type_hint",
    "ingested_at",
    "status",
    "raw"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "record_id": {
      "type": "string",
      "minLength": 1
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "domain": {
      "type": "string",
      "minLength": 1
    },
    "source_type_hint": {
      "type": "string",
      "enum": [
        "blog",
        "product_page",
        "resource_hub",
        "case_study",
        "changelog",
        "social_post",
        "unknown"
      ]
    },
    "ingested_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": ["normalized", "invalid"]
    },
    "notes": {
      "type": "string"
    },
    "raw": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input_url"],
      "properties": {
        "input_url": {
          "type": "string"
        },
        "input_metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
